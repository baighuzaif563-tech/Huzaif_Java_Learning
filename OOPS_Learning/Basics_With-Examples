class Car{
    
    String color;
String model;
String brand;

int year;
int speed;
Car(String color,String model,String brand,int year,int speed){
    this.color=color;
    this.model=model;
    this.brand=brand;
    this.year=year;
    this.speed=speed;
}

void speed(int i){
    speed=speed+i;
    System.out.println("The new Speed is "+speed);
}

void brake(int decreament){
    speed=speed-decreament;
    if(speed<0){
        speed=0;
    }
    System.out.println("The new Speed is "+speed);
}
  void display() {
        System.out.println("Brand : " + brand);
        System.out.println("Model : " + model);
        System.out.println("Color : " + color);
        System.out.println("Year  : " + year);
        System.out.println("Speed : " + speed);
    }
}
class Main {
    public static void main(String[] args) {
       Car c=new Car("Black","Punch","Tata",2016,70);
       c.speed(30);
       c.brake(20);
       c.display();
    }
}

