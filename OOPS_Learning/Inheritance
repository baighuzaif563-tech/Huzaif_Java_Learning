📌 Complete Example
class Vehicle {

    String brand;

    void setBrand(String brand) {
        this.brand = brand;
    }

    void displayBrand() {
        System.out.println("Brand: " + brand);
    }
}

class Car extends Vehicle {

    void drive() {
        System.out.println("Car is running...");
    }
}

class Main {

    public static void main(String[] args) {

        Car c = new Car();

        c.setBrand("Toyota");

        c.displayBrand();

        c.drive();
    }
}
Output
Brand: Toyota

Car is running...
